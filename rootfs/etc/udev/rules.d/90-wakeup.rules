# Enable wakeup from suspend via USB devices (keyboard/mouse)
# Enable xHCI host controller wakeup
SUBSYSTEM=="usb", ATTR{idVendor}=="1d6b", ATTR{idProduct}=="0002", ATTR{power/wakeup}="enabled"
# Enable USB hub wakeup
SUBSYSTEM=="usb", ATTR{idVendor}=="0552", ATTR{idProduct}=="1110", ATTR{power/wakeup}="enabled"

# Enable wakeup from ACPI sleep button
SUBSYSTEM=="platform", KERNEL=="PNP0C0E:00", ATTR{power/wakeup}="enabled"
